{% extends 'base.html.twig' %}
{% block body %}
{% for flash_error in app.flashes('error') %}
        <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
    {% endfor %}
    {% for flash_success in app.flashes('success') %}
        <div class="alert alert-success" role="alert">{{ flash_success }}</div>
    {% endfor %}
    
    <h1>{% block title %}SGT- Gestión Cancha - {{ sede.nombre }}{% endblock %}</h1>
    <h2>{{ sede.domicilio }}</h2>
    <a href="{{ path('admin_torneo_index') }}" class="btn btn-secondary">Volver</a>
    <a href="{{ path('admin_cancha_crear', {'ruta': ruta, 'sedeId': sede.id }) }}" class="btn btn-success">Crear</a>
    <table class="table">
        <thead>
            <tr>
                <th scope="col">#</th>
                <th scope="col">Nombre</th>
                <th scope="col">Descripción</th>
                <th scope="col" style="width: 170px;">Acciones</th>
            </tr>
        </thead>
        <tbody>
            {% for cancha in sede.canchas %}
                <tr>
                    <th scope="row">{{ loop.index }}</th>
                    <td>{{ cancha.nombre }}</td>
                    <td>{{ cancha.descripcion }}</td>
                    <td>
                        <a href="{{ path('admin_cancha_editar',{'ruta': ruta, 'sedeId': sede.id, 'canchaId': cancha.id }) }}" class="btn btn-info">Editar</a>
                        <form id="formEliminarCancha{{ cancha.id }}" action="{{ path('admin_cancha_eliminar', {'ruta': ruta, 'sedeId': sede.id, 'canchaId': cancha.id }) }}" method="post" class="d-inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_cancha_' ~ cancha.id) }}">
                            <button type="button" class="btn btn-danger js-confirm-action" data-modal-title="Eliminar Cancha" data-modal-text="¿Está seguro que desea eliminar la cancha?">Eliminar</button>
                        </form>
                </tr>
            {% endfor %}
        </tbody>
      </table>
      {% include "./componentes/modal.html.twig" %}

    <script>
        document.querySelectorAll('.js-confirm-action').forEach((btn) => {
            btn.addEventListener('click', () => {
                const form = btn.closest('form');
                if (!form) {
                    return;
                }

                crearModal(
                    btn.dataset.modalTitle || 'Confirmar acción',
                    btn.dataset.modalText || '¿Está seguro que desea continuar?',
                    () => form.submit()
                );
            });
        });
    </script>
{% endblock %}
