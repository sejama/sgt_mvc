{% extends 'base.html.twig' %}
{% block body %}

    {% for flash_error in app.flashes('error') %}
        <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
    {% endfor %}
    {% for flash_success in app.flashes('success') %}
        <div class="alert alert-success" role="alert">{{ flash_success }}</div>
    {% endfor %}
    <h1>{% block title %}SGT- Gestion Jugadores{% endblock %}</h1>
    <h3>Gestión de delegación del equipo {{ equipo.nombre }}</h3>
    <a href="{{ path('admin_equipo_index', {'ruta': ruta, 'categoriaId': categoriaId }) }}" class="btn btn-secondary">Volver</a>
    <a href="{{ path('admin_jugador_crear', {'ruta': ruta, 'categoriaId': categoriaId, 'equipoId': equipo.id }) }}" class="btn btn-success">Crear</a>
    <table class="table">
        <thead>
            <tr>
                <th scope="col">#</th>
                <th scope="col">Nombre</th>
                <th scope="col">Apellido</th>
                <th scope="col">Tipo</th>
                <th scope="col">Número</th>
                <th scope="col">Nacimiento</th>
                <th scope="col">Tipo</th>
                <th scope="col">Delegado</th>
                <th scope="col" style="width: 170px;">Acciones</th>
            </tr>
        </thead>
        <tbody>
            {% for jugador in jugadores %}
                <tr>
                    <th scope="row">{{ loop.index }}</th>
                    <td>{{ jugador.nombre }}</td>
                    <td>{{ jugador.apellido }}</td>
                    <td>{{ jugador.tipoDocumento }}</td>
                    <td>{{ jugador.numeroDocumento }}</td>
                    <td>{{ jugador.nacimiento ? jugador.nacimiento|date('d/m/Y') }}</td>
                    <td>{{ jugador.tipo }}</td>
                    <td>{{ jugador.responsable ? 'Si' : 'No' }}</td>
                    <td>
                        <a href="{{ path('admin_jugador_editar', {'ruta': ruta, 'categoriaId': categoriaId, 'equipoId': equipo.id, 'jugadorId': jugador.id }) }}" class="btn btn-info">Editar</a>
                        <form action="{{ path('admin_jugador_eliminar', {'ruta': ruta, 'categoriaId': categoriaId, 'equipoId': equipo.id, 'jugadorId': jugador.id }) }}" method="post" class="d-inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_jugador_' ~ jugador.id) }}">
                            <button type="button" class="btn btn-danger js-confirm-action" data-modal-title="Eliminar Jugador" data-modal-text="¿Está seguro que desea eliminar el jugador?">Eliminar</button>
                        </form>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
    {% include "./componentes/modal.html.twig" %}
    <script>
        document.querySelectorAll('.js-confirm-action').forEach((btn) => {
            btn.addEventListener('click', () => {
                const form = btn.closest('form');
                if (!form) {
                    return;
                }

                crearModal(
                    btn.dataset.modalTitle || 'Confirmar acción',
                    btn.dataset.modalText || '¿Está seguro que desea continuar?',
                    () => form.submit()
                );
            });
        });
    </script>
{% endblock %}

