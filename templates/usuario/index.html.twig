{% extends 'base.html.twig' %}

{% block title %}SGT- Registrar{% endblock %}

{% block body %}

    {% for flash_error in app.flashes('error') %}
        <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
    {% endfor %}
    {% for flash_success in app.flashes('success') %}
        <div class="alert alert-success" role="alert">{{ flash_success }}</div>
    {% endfor %}
    
    <h1>SGT - Usuarios</h1>
    <a href="{{ path('app_main') }}" class="btn btn-secondary">Volver</a>
    <a href="{{ path('admin_usuario_crear') }}" class="btn btn-success">Registrar</a>
    <div class="table-responsive">
        <table class="table align-middle" style="white-space: nowrap; overflow-x: auto;">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Nombre</th>
                    <th>Apellido</th>
                    <th>Usuario</th>
                    <th>Roles</th>
                    <th class="w-auto" >Acciones</th>
                </tr>
            </thead>
            <tbody>
                {% for user in usuarios %}
                    <tr>
                        <th scope="row">{{ loop.index }}</th>
                        <td>{{ user.nombre }}</td>
                        <td>{{ user.apellido }}</td>
                        <td>{{ user.username }}</td>
                        <td>
                            {% for rol in user.roles %}
                                {{ rol }}
                            {% endfor %}
                        </td>
                        <td>
                            <a href="{{ path('admin_usuario_editar', {'id': user.id}) }}" class="btn btn-info">Editar</a>
                            <form action="{{ path('admin_usuario_eliminar', {'id': user.id}) }}" method="post" class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_usuario_' ~ user.id) }}">
                                <button type="button" class="btn btn-danger js-confirm-action" data-modal-title="Eliminar Usuario" data-modal-text="¿Está seguro que desea eliminar al usuario?">Eliminar</button>
                            </form>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {% include "./componentes/modal.html.twig" %}

    <script>
        document.querySelectorAll('.js-confirm-action').forEach((btn) => {
            btn.addEventListener('click', () => {
                const form = btn.closest('form');
                if (!form) {
                    return;
                }

                crearModal(
                    btn.dataset.modalTitle || 'Confirmar acción',
                    btn.dataset.modalText || '¿Está seguro que desea continuar?',
                    () => form.submit()
                );
            });
        });
    </script>

{% endblock %}