{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .main-page .hero-main {
            background: linear-gradient(135deg, #0f172a 0%, #1f3a5f 55%, #27546c 100%);
            color: #fff;
        }

        .main-page .hero-main .text-muted {
            color: rgba(255, 255, 255, 0.72) !important;
        }

        .main-page .torneo-item {
            border: 1px solid rgba(15, 23, 42, 0.08);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .main-page .torneo-item:hover {
            transform: translateY(-2px);
            box-shadow: 0 0.75rem 1.5rem rgba(15, 23, 42, 0.1);
        }

        .main-page .btn-torneo-activo {
            background-color: #1f6feb;
            border-color: #1f6feb;
        }

        .main-page .btn-torneo-disputado {
            background-color: #64748b;
            border-color: #64748b;
        }
    </style>
{% endblock %}

{% block title %}SGT - Inicio{% endblock %}

{% block body %}
<div class="main-page py-3">
    {% for flash_error in app.flashes('error') %}
    <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
    {% endfor %}
    {% for flash_success in app.flashes('success') %}
    <div class="alert alert-success" role="alert">{{ flash_success }}</div>
    {% endfor %}

    <div class="card border-0 shadow-sm hero-main mb-4">
        <div class="card-body p-4 p-md-5">
            <h1 class="h3 mb-2">Bienvenido al Sistema de Gestión de Torneo</h1>
            <p class="mb-0 text-muted">Visualiza torneos activos y disputados, y entra a cada uno para consultar programación, tablas y resultados.</p>
        </div>
    </div>
    
    {% set ahora = "now"|date("U") %}
    {% set torneosActivos = [] %}
    {% set torneosDisputados = [] %}
    
    {% for torneo in torneos %}
        {% if torneo.fechaFinTorneo|date("U") > ahora %}
            {% set torneosActivos = torneosActivos|merge([torneo]) %}
        {% else %}
            {% set torneosDisputados = torneosDisputados|merge([torneo]) %}
        {% endif %}
    {% endfor %}
    
    {% if torneosActivos|length > 0 %}
        <h2 class="h4 mt-4 mb-3">Torneos Activos</h2>
        <div class="row g-3 mb-4">
            {% for torneo in torneosActivos %}
                <div class="col-12 col-md-6">
                    <article class="card torneo-item h-100">
                        <div class="card-body d-flex flex-column gap-3">
                            <h3 class="h6 mb-0">{{ torneo.nombre }}</h3>
                            <a class="btn btn-primary btn-torneo-activo mt-auto" href="{{ path('app_main_torneo', {'ruta': torneo.ruta}) }}" role="button">
                                Ver torneo
                            </a>
                        </div>
                    </article>
                </div>
            {% endfor %}
        </div>
    {% endif %}
    
    {% if torneosDisputados|length > 0 %}
        <h2 class="h4 mt-2 mb-3">Torneos Disputados</h2>
        <div class="row g-3">
            {% for torneo in torneosDisputados %}
                <div class="col-12 col-md-6">
                    <article class="card torneo-item h-100">
                        <div class="card-body d-flex flex-column gap-3">
                            <h3 class="h6 mb-0">{{ torneo.nombre }}</h3>
                            <a class="btn btn-secondary btn-torneo-disputado mt-auto" href="{{ path('app_main_torneo', {'ruta': torneo.ruta}) }}" role="button">
                                Ver torneo
                            </a>
                        </div>
                    </article>
                </div>
            {% endfor %}
        </div>
    {% endif %}
    {#}
    {% include "./componentes/fixture.html.twig" %}
    {{ include ("./componentes/tabla.html.twig", {'categoria': categoria}) }}
    #}
</div>
{% endblock %}
