{% extends 'base.html.twig' %}

{% block stylesheets %}
  {{ parent() }}
  <style>
    .torneo-page .hero-torneo {
      background: linear-gradient(135deg, #0f172a 0%, #1f3a5f 55%, #27546c 100%);
      color: #fff;
    }

    .torneo-page .hero-torneo .text-muted {
      color: rgba(255, 255, 255, 0.72) !important;
    }

    .torneo-page .hero-torneo .selector-tabla {
      min-width: 260px;
      border: 1px solid rgba(255, 255, 255, 0.45);
      background: rgba(255, 255, 255, 0.1);
      color: #fff;
      backdrop-filter: blur(6px);
    }

    .torneo-page .hero-torneo .selector-tabla option {
      color: #0f172a;
      background: #fff;
    }

    .torneo-page .hero-torneo .filtros-torneo {
      margin-top: 1.25rem;
      padding-top: 1rem;
      border-top: 1px solid rgba(255, 255, 255, 0.2);
    }

    .torneo-page .hero-torneo .filtros-torneo .form-label {
      color: rgba(255, 255, 255, 0.75);
      margin-bottom: 0.35rem;
      font-size: 0.85rem;
    }

    .torneo-page .hero-torneo .filtros-torneo .form-select {
      background: rgba(255, 255, 255, 0.12);
      color: #fff;
      border: 1px solid rgba(255, 255, 255, 0.45);
    }

    .torneo-page .hero-torneo .filtros-torneo .form-select option {
      color: #0f172a;
      background: #fff;
    }

    .torneo-page .hero-torneo .filtros-torneo .btn-limpiar-filtros {
      border-color: rgba(255, 255, 255, 0.55);
      color: #fff;
    }

    .torneo-page .hero-torneo .filtros-torneo .btn-limpiar-filtros:hover,
    .torneo-page .hero-torneo .filtros-torneo .btn-limpiar-filtros:focus {
      color: #0f172a;
      background: #fff;
      border-color: #fff;
    }

    .torneo-page .equipo-chip {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      gap: 0.28rem;
      min-width: 0;
      min-height: 7.2rem;
      padding: 0.22rem 0.48rem 0.46rem;
      border-radius: 0.9rem;
      border: 1px solid rgba(148, 163, 184, 0.22);
      background: linear-gradient(180deg, rgba(248, 250, 252, 0.96), rgba(241, 245, 249, 0.85));
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.85);
      text-align: center;
      overflow: hidden;
      transition: border-color 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
    }

    .torneo-page .equipo-chip:hover {
      border-color: rgba(59, 130, 246, 0.38);
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(241, 245, 249, 0.92));
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.92), 0 8px 16px rgba(15, 23, 42, 0.08);
    }

    .torneo-page .equipo-chip .logo-shell {
      position: relative;
      width: 74px;
      height: 74px;
      max-width: 100%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 999px;
      background: radial-gradient(circle at 30% 30%, #ffffff 0%, #f1f5f9 75%);
      border: 1px solid #d9e3ef;
      box-shadow: 0 8px 18px rgba(15, 23, 42, 0.16);
    }

    .torneo-page .equipo-chip .logo-shell::after {
      content: '';
      position: absolute;
      inset: -2px;
      border-radius: 999px;
      border: 1px solid rgba(37, 84, 108, 0.24);
      pointer-events: none;
    }

    .torneo-page .equipo-chip .logo-equipo {
      width: 58px;
      height: 58px;
      object-fit: contain;
      border-radius: 999px;
      border: 2px solid #e2e8f0;
      background: #fff;
      flex-shrink: 0;
      box-shadow: 0 4px 10px rgba(15, 23, 42, 0.14);
      transition: transform 0.2s ease;
    }

    .torneo-page .partido-card:hover .equipo-chip .logo-equipo {
      transform: scale(1.05);
    }

    .torneo-page .equipo-chip .nombre-equipo {
      min-width: 0;
      max-width: 100%;
      overflow-wrap: anywhere;
      line-height: 1.1;
      letter-spacing: 0.01em;
      font-weight: 600;
      font-size: 0.82rem;
      text-align: center;
      margin-top: 0.24rem;
    }

    .torneo-page .partido-card {
      border: 1px solid rgba(15, 23, 42, 0.08);
      border-radius: 1.1rem;
      overflow: hidden;
      box-shadow: 0 0.75rem 1.5rem rgba(15, 23, 42, 0.08);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .torneo-page .partido-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 1rem 2rem rgba(15, 23, 42, 0.12);
    }

    .torneo-page .partido-card .partido-cuerpo {
      display: grid;
      gap: 1rem;
    }

    .torneo-page .partido-card .partido-contra {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      gap: 0.75rem;
      align-items: center;
    }

    .torneo-page .partido-card .partido-vs {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 3rem;
      height: 3rem;
      border-radius: 999px;
      font-weight: 800;
      color: #1f3a5f;
      background: #eef4fb;
      border: 1px solid #d8e4f3;
      margin: 0 auto;
    }

    .torneo-page .partido-card .partido-vs-subtexto {
      display: block;
      margin-top: 0.35rem;
      font-size: 0.76rem;
      letter-spacing: 0.01em;
      line-height: 1.25;
      max-width: 10.5rem;
    }

    .torneo-page .partido-card .partido-vs-subtexto .partido-vs-hora {
      display: block;
      font-weight: 700;
      color: #334155;
      font-size: 0.96rem;
      line-height: 1.1;
    }

    .torneo-page .partido-card .partido-vs-subtexto .partido-vs-contexto {
      display: block;
    }

    .torneo-page .partido-card .equipo-col {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
      align-items: stretch;
    }

    .torneo-page .partido-card .partido-score-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem;
      justify-content: center;
    }

    .torneo-page .partido-card .partido-score-chip {
      min-width: 2.1rem;
      text-align: center;
      padding: 0.28rem 0.45rem;
      border-radius: 999px;
      background: #f8fafc;
      color: #0f172a;
      border: 1px solid #dbe4f0;
      font-weight: 700;
      line-height: 1;
    }

    .torneo-page .partido-card .partido-score-chip.partido-score-chip--empty {
      color: #94a3b8;
      background: #f8fafc;
      font-weight: 600;
    }

    @media (max-width: 767.98px) {
      .torneo-page .hero-torneo .card-body {
        padding: 1rem !important;
      }

      .torneo-page .hero-torneo h1 {
        font-size: 1.15rem;
        margin-bottom: 0.35rem !important;
      }

      .torneo-page .hero-torneo p {
        font-size: 0.85rem;
      }

      .torneo-page .hero-torneo .selector-tabla {
        min-width: 0;
        width: 100%;
      }

      .torneo-page .hero-torneo .filtros-torneo {
        margin-top: 0.75rem;
        padding-top: 0.75rem;
      }

      .torneo-page .hero-torneo .filtros-torneo .form-label {
        font-size: 0.75rem;
        margin-bottom: 0.2rem;
      }

      .torneo-page .hero-torneo .filtros-torneo .form-select,
      .torneo-page .hero-torneo .filtros-torneo .btn {
        font-size: 0.85rem;
        padding-top: 0.35rem;
        padding-bottom: 0.35rem;
      }

      .torneo-page .container-fluid .row.g-3 {
        --bs-gutter-x: 0.6rem;
        --bs-gutter-y: 0.6rem;
      }

      .torneo-page .partido-card {
        border-radius: 0.9rem;
      }

      .torneo-page .equipo-chip {
        min-height: 5.5rem;
        gap: 0.16rem;
        padding: 0.16rem 0.2rem 0.28rem;
      }

      .torneo-page .equipo-chip .logo-equipo {
        width: 40px;
        height: 40px;
      }

      .torneo-page .equipo-chip .logo-shell {
        width: 50px;
        height: 50px;
      }

      .torneo-page .equipo-chip .nombre-equipo {
        font-size: 0.67rem;
        line-height: 1.05;
        margin-top: 0.18rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      .torneo-page .partido-card .card-body {
        padding: 0.62rem !important;
      }

      .torneo-page .partido-card .partido-cuerpo {
        gap: 0.42rem;
      }

      .torneo-page .partido-card .partido-contra {
        grid-template-columns: 1fr auto 1fr;
        gap: 0.25rem;
        align-items: start;
      }

      .torneo-page .partido-card .partido-vs {
        width: 1.95rem;
        height: 1.95rem;
        font-size: 0.64rem;
      }

      .torneo-page .partido-card .partido-vs-subtexto {
        margin-top: 0.2rem;
        font-size: 0.56rem;
        line-height: 1.15;
        max-width: none;
      }

      .torneo-page .partido-card .partido-vs-subtexto .partido-vs-hora {
        font-size: 0.72rem;
      }

      .torneo-page .partido-card .equipo-col {
        gap: 0.16rem;
      }

      .torneo-page .partido-card .partido-score-chips {
        gap: 0.24rem;
        justify-content: center;
      }

      .torneo-page .partido-card .partido-score-chip {
        min-width: 1.45rem;
        padding: 0.2rem 0.3rem;
        font-size: 0.66rem;
      }

    }

    @media (orientation: landscape) and (max-height: 500px) {
      .torneo-page .partido-card .partido-score-chips {
        flex-wrap: nowrap;
        gap: 0.16rem;
      }

      .torneo-page .partido-card .partido-score-chip {
        min-width: 1.25rem;
        padding: 0.16rem 0.2rem;
        font-size: 0.6rem;
      }
    }
  </style>
{% endblock %}

{% block title %}SGT - Inicio{% endblock %}

{% block body %}
{% for flash_error in app.flashes('error') %}
    <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
    {% endfor %}
    {% for flash_success in app.flashes('success') %}
    <div class="alert alert-success" role="alert">{{ flash_success }}</div>
    {% endfor %}
<div class="torneo-page py-3">
  <div class="card border-0 shadow-sm hero-torneo mb-4">
    <div class="card-body p-4 p-md-5">
      <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-lg-start">
        <div class="flex-grow-1">
          <h1 class="h3 mb-2">{{ torneo.nombre }}</h1>
          <p class="mb-0 text-muted">Partidos programados y filtros por categoría y equipo.</p>
        </div>
        <div class="d-flex flex-column align-items-start align-items-lg-end gap-2">
          <label for="selectorTablaCategoria" class="small text-white-50 mb-0">Ver tabla por categoría</label>
          <select id="selectorTablaCategoria" class="form-select selector-tabla" aria-label="Ver tabla por categoría" onchange="location.href=this.value;">
            <option selected value="">Seleccionar categoría</option>
            {% for categoria in categorias %}
                <option value="{{ path('app_main_categoria', {'ruta': torneo.ruta, 'categoriaId': categoria.id}) }}">
                    {{ categoria.nombre }}
                </option>
            {% endfor %}
          </select>
        </div>
      </div>

      <form method="get" id="filtersForm" class="filtros-torneo">
        <div class="row g-2 align-items-end">
          <div class="col-6 col-md-5 col-lg-4">
            <label for="filtroCategoria" class="form-label">Filtrar por categoría</label>
            <select id="filtroCategoria" name="categoria" class="form-select" onchange="document.getElementById('filtersForm').submit();">
              <option value="">Todas las categorías</option>
              {% for categoria in categorias %}
                <option value="{{ categoria.id }}" {% if categoria.id == selectedCategoriaId %}selected{% endif %}>{{ categoria.nombre }}</option>
              {% endfor %}
            </select>
          </div>

          <div class="col-6 col-md-5 col-lg-4">
            <label for="filtroEquipo" class="form-label">Filtrar por equipo</label>
            <select id="filtroEquipo" name="equipo" class="form-select" onchange="document.getElementById('filtersForm').submit();">
              <option value="">Todos los equipos</option>
              {% if equipos is defined %}
                {% for equipo in equipos %}
                  <option value="{{ equipo.id }}" {% if equipo.id == selectedEquipoId %}selected{% endif %}>{{ equipo.nombre }}</option>
                {% endfor %}
              {% endif %}
            </select>
          </div>

          <div class="col-12 col-md-2 col-lg-2">
            <a href="{{ path('app_main_torneo', {'ruta': torneo.ruta}) }}" class="btn btn-outline-light btn-limpiar-filtros w-100">Limpiar</a>
          </div>
        </div>
      </form>
    </div>
  </div>

  <div class="container-fluid px-0">
  {% for cancha, canchas in partidosProgramados %}
    <h3 class="mt-4 mb-3">{{ cancha }}</h3>
    {% for fecha, fechas in canchas %}
      <h4 class="mt-3 mb-3">{{ fecha }}</h4>
      {% for dia, partidos in fechas %}
        <div class="row g-3 mb-4">
          <div class="col-12">
            <div class="card h-100 shadow-sm">
              <div class="card-header bg-light">
                <strong>{{ dia }}</strong>
              </div>
              <div class="card-body">
                <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3">
                  {% for idx, partido in partidos %}
                    {% set localScores = [partido.localSet1, partido.localSet2, partido.localSet3, partido.localSet4, partido.localSet5]|filter(v => v is not null and v != '') %}
                    {% set visitanteScores = [partido.visitanteSet1, partido.visitanteSet2, partido.visitanteSet3, partido.visitanteSet4, partido.visitanteSet5]|filter(v => v is not null and v != '') %}
                    <div class="col">
                      <article class="card partido-card h-100">
                        <div class="card-body p-3 p-md-4">
                          <div class="partido-cuerpo">
                            <div class="partido-contra">
                              <div class="min-w-0 equipo-col">
                                {% set logoLocal = partido.equipoLocalLogoPath|default('uploads/logos/sin_logo.png') %}
                                <div class="equipo-chip fw-semibold w-100">
                                  <span class="logo-shell"><img src="{{ asset(logoLocal) }}" alt="Logo de {{ partido.equipoLocal }}" class="logo-equipo"></span>
                                  <span class="nombre-equipo">{{ partido.equipoLocal }}</span>
                                </div>
                                <div class="partido-score-chips">
                                  {% if localScores|length > 0 %}
                                    {% for score in localScores %}
                                      <span class="partido-score-chip">{{ score }}</span>
                                    {% endfor %}
                                  {% else %}
                                    <span class="partido-score-chip partido-score-chip--empty">-</span>
                                  {% endif %}
                                </div>
                              </div>

                              <div class="text-center">
                                <span class="partido-vs">VS</span>
                                <small class="partido-vs-subtexto text-muted">
                                  <span class="partido-vs-hora">{{ partido.hora|date('H:i') }} hs</span>
                                  <span class="partido-vs-contexto">{{ partido.categoriaCorta|default(partido.categoria) }} - {{ partido.grupo }}</span>
                                </small>
                              </div>

                              <div class="min-w-0 equipo-col">
                                {% set logoVisitante = partido.equipoVisitanteLogoPath|default('uploads/logos/sin_logo.png') %}
                                <div class="equipo-chip fw-semibold w-100">
                                  <span class="logo-shell"><img src="{{ asset(logoVisitante) }}" alt="Logo de {{ partido.equipoVisitante }}" class="logo-equipo"></span>
                                  <span class="nombre-equipo">{{ partido.equipoVisitante }}</span>
                                </div>
                                <div class="partido-score-chips">
                                  {% if visitanteScores|length > 0 %}
                                    {% for score in visitanteScores %}
                                      <span class="partido-score-chip">{{ score }}</span>
                                    {% endfor %}
                                  {% else %}
                                    <span class="partido-score-chip partido-score-chip--empty">-</span>
                                  {% endif %}
                                </div>
                              </div>
                            </div>
                          </div>
                        </div>
                      </article>
                    </div>
                  {% endfor %}
                </div>
              </div>
            </div>
          </div>
        </div>
      {% endfor %}
    {% endfor %}
  {% endfor %}
    </div>
  </div>
{% endblock %}