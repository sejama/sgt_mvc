{% extends 'base.html.twig' %}

{% block title %}SGT - Inicio{% endblock %}

{% block body %}
{% for flash_error in app.flashes('error') %}
    <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
    {% endfor %}
    {% for flash_success in app.flashes('success') %}
    <div class="alert alert-success" role="alert">{{ flash_success }}</div>
    {% endfor %}
<div class="container-fluid">
  <h1>{{ torneo.nombre }}</h1>
  <select class="form-select" aria-label="Default select example" onchange="location.href=this.value;">
    <option selected>Ver Tabla</option>
    {% for categoria in categorias %}
        <option value="{{ path('app_main_categoria', {'ruta': torneo.ruta, 'categoriaId': categoria.id}) }}">
            {{ categoria.nombre }}
        </option>
    {% endfor %}
</select>
<form method="get" id="filtersForm" class="mb-3 mt-3">
  <div class="row g-2 align-items-center">
    <div class="col-auto">
      <select name="categoria" class="form-select" onchange="document.getElementById('filtersForm').submit();">
        <option value="">Filtrar por categorías</option>
        {% for categoria in categorias %}
          <option value="{{ categoria.id }}" {% if categoria.id == selectedCategoriaId %}selected{% endif %}>{{ categoria.nombre }}</option>
        {% endfor %}
      </select>
    </div>

    <div class="col-auto">
      <select name="equipo" class="form-select" onchange="document.getElementById('filtersForm').submit();">
        <option value="">Filtrar por equipo</option>
        {% if equipos is defined %}
          {% for equipo in equipos %}
            <option value="{{ equipo.id }}" {% if equipo.id == selectedEquipoId %}selected{% endif %}>{{ equipo.nombre }}</option>
          {% endfor %}
        {% endif %}
      </select>
    </div>

    <div class="col-auto">
      <a href="{{ path('app_main_torneo', {'ruta': torneo.ruta}) }}" class="btn btn-outline-secondary">Limpiar</a>
    </div>
  </div>
</form>
  {% for cancha, canchas in partidosProgramados %}
    <h3 class="mt-4 mb-3">{{ cancha }}</h3>
    {% for fecha, fechas in canchas %}
      <h4 class="mt-3 mb-3">{{ fecha }}</h4>
      {% for dia, partidos in fechas %}
        <div class="row g-3 mb-4">
          <div class="col-12">
            <div class="card h-100 shadow-sm">
              <div class="card-header bg-light">
                <strong>{{ dia }}</strong>
              </div>
              <div class="card-body">
                <div class="row row-cols-1 row-cols-lg-2 row-cols-xxl-3 g-2">
                  {% for idx, partido in partidos %}
                    {% set localScores = [partido.localSet1, partido.localSet2, partido.localSet3]|filter(v => v is not null and v != '') %}
                    {% set visitanteScores = [partido.visitanteSet1, partido.visitanteSet2, partido.visitanteSet3]|filter(v => v is not null and v != '') %}
                    <div class="col">
                      <div class="border rounded p-2 h-100">
                        <div class="d-flex flex-wrap gap-2 align-items-center mb-1">
                          <span class="badge bg-primary">{{ partido.hora|date('H:i') }}</span>
                          <small class="text-muted">{{ partido.categoria }} / {{ partido.grupo }}</small>
                        </div>
                        <div class="row align-items-start g-1 mt-1">
                          <div class="col-5 text-start">
                            <div class="fw-semibold small">{{ partido.equipoLocal }}</div>
                            <small class="text-muted d-block mt-1">
                              {% if localScores|length > 0 %}
                                {{ localScores|join(' ') }}
                              {% else %}
                                -
                              {% endif %}
                            </small>
                          </div>
                          <div class="col-2 text-center">
                            <span class="badge bg-secondary">VS</span>
                          </div>
                          <div class="col-5 text-end">
                            <div class="fw-semibold small">{{ partido.equipoVisitante }}</div>
                            <small class="text-muted d-block mt-1">
                              {% if visitanteScores|length > 0 %}
                                {{ visitanteScores|join(' ') }}
                              {% else %}
                                -
                              {% endif %}
                            </small>
                          </div>
                        </div>
                      </div>
                    </div>
                  {% endfor %}
                </div>
              </div>
            </div>
          </div>
        </div>
      {% endfor %}
    {% endfor %}
  {% endfor %}
  </div>
{% endblock %}