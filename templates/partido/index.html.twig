{% extends 'base.html.twig' %}

{% block body %}
    {% for flash_error in app.flashes('error') %}
        <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
    {% endfor %}
    {% for flash_success in app.flashes('success') %}
        <div class="alert alert-success" role="alert">{{ flash_success }}</div>
    {% endfor %}
    {% for flash_warning in app.flashes('warning') %}
      <div class="alert alert-warning" role="alert">{{ flash_warning }}</div>
    {% endfor %}
    {% set esPrimerPartido = partidosProgramados|length == 0 %}
    <h1>{% block title %}SGT- Gestion Partidos{% endblock %}</h1>
    <a href="{{ path('admin_torneo_index') }}" class="btn btn-secondary">Volver</a>
    <a href="{{ path('admin_partido_gestionar', { 'ruta': torneo.ruta }) }}" class="btn btn-primary">Agregar/Editar partido</a>
    <h3>Partidos clasificatorios</h3>
    {% if partidosSinAsignar['clasificatorios']|length == 0 %}
        <div class="alert alert-warning" role="alert">
            No hay partidos clasificatorios sin asignar
        </div>
    {% else %}
    <table class="table table-striped">
        <thead>
          <tr>
            <th scope="col">#</th>
            <th scope="col">Cancha</th>
            <th scope="col">Horario</th>
            <th scope="col">Categoría</th>
            <th scope="col">Grupo</th>
            <th scope="col">Local</th>
            <th scope="col">vs</th>
            <th scope="col">Visitante</th>
            <th scope="col">Acciones</th>
          </tr>
        </thead>
        <tbody class="table-group-divider">
          {% for partido in partidosSinAsignar['clasificatorios'] %}
            <tr>
                <th scope="row">{{ partido.numero }}</th>
                <td>
                  <select class="form-select" aria-label="Default select example" id="cancha{{partido.id}}" name="cancha{{partido.id}}">
                    <option value="" selected>Seleccionar Cancha</option>
                    {% for key,sede in canchas %}
                      <optgroup label="{{key}}">	
                      {% for cancha in sede %}
                        <option value="{{ cancha['id'] }}" data-sede-id="{{ cancha['sedeId'] }}">{{ cancha['cancha'] }}</option>
                      {% endfor %}
                      </optgroup>
                    {% endfor %}
                  </select>
                </td>
                <td>
                    <input type="datetime-local" class="form-control" id="horario{{partido.id}}" name="horario{{partido.id}}" 
                      min="{{ partido.fechaInicioTorneo|date('Y-m-d\\TH:i') }}"
                      max="{{ partido.fechaFinTorneo|date('Y-m-d\\TH:i') }}"
                      step="900"
                      data-force-inicio="{{ esPrimerPartido ? '1' : '0' }}"
                      data-inicio-torneo="{{ partido.fechaInicioTorneo|date('Y-m-d\\TH:i') }}"
                      disabled
                    >
                    <small id="ayudaHorario{{ partido.id }}" class="form-text text-muted d-block mt-1">Seleccioná cancha para habilitar horario y ver disponibilidad.</small>
                </td>
                <td>{{ partido.categoria }}</td>
                <td>{{ partido.grupo }}</td>
                <td>{{ partido.equipoLocal }}</td>
                <td>-</td>
                <td>{{ partido.equipoVisitante }}</td>
                <td>
                  <form action="{{ path('admin_partido_editar', { 'ruta': torneo.ruta }) }}" method="post" style="display: inline;">
                    <input type="hidden" name="var_partidoId" name="var_partidoId" value={{ partido.id }}>
                    <input type="hidden" id="var_cancha{{ partido.id }}" name="var_cancha" value="">
                    <input type="hidden" id="var_horario{{ partido.id }}" name="var_horario" value="">
                    <button id="admin_partido_editar{{partido.id}}" class="btn btn-primary disabled" type="submit">Guardar</button>
                  </form>
              </td>
            </tr>  
          {% endfor %}
        </tbody>
      </table>
      {% endif %}
      <h3>Partidos eliminatorios post grupos</h3>
      {% if partidosSinAsignar['eliminatorias']|length == 0 %}
        <div class="alert alert-warning" role="alert">
            No hay partidos eliminatorios sin asignar
        </div>
      {% else %}
      <table class="table table-striped">
        <thead>
          <tr>
            <th scope="col">#</th>
            <th scope="col">Cancha</th>
            <th scope="col">Horario</th>
            <th scope="col">Categoría</th>
            <th scope="col">Partido</th>
            <th scope="col">Local</th>
            <th scope="col">vs</th>
            <th scope="col">Visitante</th>
            <th scope="col">Acciones</th>
          </tr>
        </thead>
        <tbody class="table-group-divider">
      {% for partido in partidosSinAsignar['eliminatorias'] %}
      <tr>
        <th scope="row">{{ partido.numero }}</th>
        <td>
          <select class="form-select" aria-label="Default select example" id="cancha{{partido.id}}" name="cancha{{partido.id}}">
            <option value="" selected>Seleccionar Cancha</option>
            {% for key,sede in canchas %}
              <optgroup label="{{key}}">	
              {% for cancha in sede %}
                <option value="{{ cancha['id'] }}" data-sede-id="{{ cancha['sedeId'] }}">{{ cancha['cancha'] }}</option>
              {% endfor %}
              </optgroup>
            {% endfor %}
          </select>
        </td>
        <td>
            <input type="datetime-local" class="form-control" id="horario{{partido.id}}" name="horario{{partido.id}}" 
              min="{{ partido.fechaInicioTorneo|date('Y-m-d\\TH:i') }}"
              max="{{ partido.fechaFinTorneo|date('Y-m-d\\TH:i') }}"
              step="900"
              data-force-inicio="{{ esPrimerPartido ? '1' : '0' }}"
              data-inicio-torneo="{{ partido.fechaInicioTorneo|date('Y-m-d\\TH:i') }}"
              disabled
            >
            <small id="ayudaHorario{{ partido.id }}" class="form-text text-muted d-block mt-1">Seleccioná cancha para habilitar horario y ver disponibilidad.</small>
        </td>
        <td>{{ partido.categoria }}</td>
        <td>{{ partido.nombre }}</td>
        <td>{{ partido.equipoLocal }}</td>
        <td>-</td>
        <td>{{ partido.equipoVisitante }}</td>
        <td>
          <form action="{{ path('admin_partido_editar', { 'ruta': torneo.ruta }) }}" method="post" style="display: inline;">
            <input type="hidden" name="var_partidoId" name="var_partidoId" value={{ partido.id }}>
            <input type="hidden" id="var_cancha{{ partido.id }}" name="var_cancha" value="">
            <input type="hidden" id="var_horario{{ partido.id }}" name="var_horario" value="">
            <button id="admin_partido_editar{{partido.id}}" class="btn btn-primary disabled" type="submit">Guardar</button>
          </form>
      </td>
    </tr>
      {% endfor %}
    </tbody>
  </table>
  {% endif %}
  <h3>Partidos eliminatorios finales</h3>
  {% if partidosSinAsignar['finales']|length == 0 %}
        <div class="alert alert-warning" role="alert">
            No hay partidos eliminatorios sin asignar
        </div>
      {% else %}
      <table class="table table-striped">
        <thead>
          <tr>
            <th scope="col">#</th>
            <th scope="col">Cancha</th>
            <th scope="col">Horario</th>
            <th scope="col">Categoría</th>
            <th scope="col">Partido</th>
            <th scope="col">Local</th>
            <th scope="col">vs</th>
            <th scope="col">Visitante</th>
            <th scope="col">Acciones</th>
          </tr>
        </thead>
        <tbody class="table-group-divider">
      {% for partido in partidosSinAsignar['finales'] %}
      <tr>
        <th scope="row">{{ partido.numero }}</th>
        <td>
          <select class="form-select" aria-label="Default select example" id="cancha{{partido.id}}" name="cancha{{partido.id}}">
            <option value="" selected>Seleccionar Cancha</option>
            {% for key,sede in canchas %}
              <optgroup label="{{key}}">	
              {% for cancha in sede %}
                <option value="{{ cancha['id'] }}" data-sede-id="{{ cancha['sedeId'] }}">{{ cancha['cancha'] }}</option>
              {% endfor %}
              </optgroup>
            {% endfor %}
          </select>
        </td>
        <td>
            <input type="datetime-local" class="form-control" id="horario{{partido.id}}" name="horario{{partido.id}}" 
              min="{{ partido.fechaInicioTorneo|date('Y-m-d\\TH:i') }}"
              max="{{ partido.fechaFinTorneo|date('Y-m-d\\TH:i') }}"
              step="900"
              data-force-inicio="{{ esPrimerPartido ? '1' : '0' }}"
              data-inicio-torneo="{{ partido.fechaInicioTorneo|date('Y-m-d\\TH:i') }}"
              disabled
            >
            <small id="ayudaHorario{{ partido.id }}" class="form-text text-muted d-block mt-1">Seleccioná cancha para habilitar horario y ver disponibilidad.</small>
        </td>
        <td>{{ partido.categoria }}</td>
        <td>{{ partido.nombre }}</td>
        <td>{{ partido.equipoPartidoLocalGanador ?? partido.equipoPartidoLocalPerdedor}} </td>
        <td>-</td>
        <td>{{ partido.equipoPartidoVisitanteGanador ?? partido.equipoPartidoVisitantePerdedor}}</td>
        <td>
          <form action="{{ path('admin_partido_editar', { 'ruta': torneo.ruta }) }}" method="post" style="display: inline;">
            <input type="hidden" name="var_partidoId" name="var_partidoId" value={{ partido.id }}>
            <input type="hidden" id="var_cancha{{ partido.id }}" name="var_cancha" value="">
            <input type="hidden" id="var_horario{{ partido.id }}" name="var_horario" value="">
            <button id="admin_partido_editar{{partido.id}}" class="btn btn-primary disabled" type="submit">Guardar</button>
          </form>
      </td>
    </tr>
      {% endfor %}
    </tbody>
  </table>
      {% endif %}
      <h3>Partidos programados</h3>
      {# dump(partidosProgramados) #}
      {% if partidosProgramados|length == 0 %}
        <div class="alert alert-warning" role="alert">
            No hay partidos programados
        </div>
        {% endif %}
      {% for key, canchas in partidosProgramados %}
        <h3>{{ key }}</h3>
        {% for key, fechas in canchas %}
          <h4>{{ key }}</h4>
          {% for key, partidos in fechas %}
            <h5>{{ key }}</h5>
          <table class="table table-striped">
            <thead>
              <tr>
                <th scope="col">#</th>
                <th scope="col">Hora</th>
                <th scope="col">Categoría</th>
                <th scope="col">Grupo</th>
                <th scope="col">Local</th>
                <th scope="col">vs</th>
                <th scope="col">Visitante</th>
                <th scope="col">Acciones</th>
              </tr>
            </thead>
            <tbody class="table-group-divider">
            {% for key, partido in partidos  %}
              <tr>
                <th scope="row">{{partido.numero}}</th>
                <td>{{ partido.hora|date('H:i') }}</td>
                <td>{{ partido.categoria }}</td>
                <td>{{ partido.grupo }}</td>
                <td>{{ partido.equipoLocal }} {{ partido.localSet1 }} {{ partido.localSet2 }} {{ partido.localSet3 }} {{ partido.localSet4 }} {{ partido.localSet5 }}</td>
                <td>-</td>
                <td>{{ partido.equipoVisitante }} {{ partido.visitanteSet1 }} {{ partido.visitanteSet2 }} {{ partido.visitanteSet3 }} {{ partido.visitanteSet4 }} {{ partido.visitanteSet5 }}</td>
                <td>
                  {% if partido.localSet1 is null and partido.visitanteSet1 is null %}
                    <a href="{{ path('admin_partido_resultado', { 'ruta': torneo.ruta, 'partidoNumero': partido.numero }) }}" class="btn btn-info">Cargar Resultado</a>
                  {% endif %}
                    <a href="{{ path('admin_partido_pdf', { 'ruta': torneo.ruta, 'partidoNumero': partido.numero }) }}" class="btn btn-secondary" target="_blank" rel="noopener">PDF</a>
                </td>
              </tr>
            {% endfor %}
            </tbody>
          </table>
        {% endfor %}
      {% endfor %}
      {% endfor %}
  <script id="horarios-programados-payload" type="application/json">{{ horariosProgramados|json_encode|raw }}</script>
  <script>
    const payloadEl = document.getElementById('horarios-programados-payload');
    const horariosProgramados = payloadEl ? JSON.parse(payloadEl.textContent || '{}') : {};
    const porCancha = horariosProgramados.porCancha || {};
    const porSede = horariosProgramados.porSede || {};

    function toSet(values) {
      return new Set(Array.isArray(values) ? values : []);
    }

    function actualizarAyudaHorario(partidoId, canchaId, sedeId) {
      const ayuda = document.getElementById('ayudaHorario' + partidoId);
      if (!ayuda) {
        return;
      }

      if (!canchaId) {
        ayuda.textContent = 'Seleccioná cancha para habilitar horario y ver disponibilidad.';
        return;
      }

      const canchaOcupados = (porCancha[canchaId] || []).slice(0, 3).join(', ');
      const sedeOcupados = (porSede[sedeId] || []).slice(0, 3).join(', ');

      if (!canchaOcupados && !sedeOcupados) {
        ayuda.textContent = 'No hay horarios ocupados para la cancha/sede seleccionada.';
        return;
      }

      let mensaje = 'Ocupados';
      if (canchaOcupados) {
        mensaje += ' cancha: ' + canchaOcupados + '.';
      }
      if (sedeOcupados) {
        mensaje += ' sede: ' + sedeOcupados + '.';
      }

      ayuda.textContent = mensaje;
    }

    function validarHorario(partidoId) {
      const canchaSelect = document.getElementById('cancha' + partidoId);
      const horarioInput = document.getElementById('horario' + partidoId);
      const hiddenHorario = document.getElementById('var_horario' + partidoId);
      const botonGuardar = document.getElementById('admin_partido_editar' + partidoId);

      if (!canchaSelect || !horarioInput || !hiddenHorario || !botonGuardar) {
        return;
      }

      const canchaId = canchaSelect.value;
      const sedeId = canchaSelect.options[canchaSelect.selectedIndex]?.dataset?.sedeId || '';
      const canchaSlots = toSet(porCancha[canchaId]);
      const sedeSlots = toSet(porSede[sedeId]);
      const valor = horarioInput.value;

      let error = '';
      if (valor) {
        if (canchaSlots.has(valor)) {
          error = 'Ese horario ya está ocupado en la cancha seleccionada.';
        } else if (sedeSlots.has(valor)) {
          error = 'Ese horario ya está ocupado en la sede seleccionada.';
        }
      }

      horarioInput.setCustomValidity(error);
      horarioInput.reportValidity();

      const puedeGuardar = canchaId && valor && !error;
      hiddenHorario.value = puedeGuardar ? valor : '';
      botonGuardar.classList.toggle('disabled', !puedeGuardar);
    }

    document.querySelectorAll('select[id^="cancha"]').forEach((element) => {
      element.addEventListener('change', (event) => {
        const partidoId = event.target.id.replace('cancha', '');
        const canchaId = event.target.value;
        const sedeId = event.target.options[event.target.selectedIndex]?.dataset?.sedeId || '';
        const horarioInput = document.getElementById('horario' + partidoId);
        const hiddenCancha = document.getElementById('var_cancha' + partidoId);

        if (!horarioInput || !hiddenCancha) {
          return;
        }

        hiddenCancha.value = canchaId || '';
        actualizarAyudaHorario(partidoId, canchaId, sedeId);

        if (!canchaId) {
          horarioInput.value = '';
          horarioInput.disabled = true;
          validarHorario(partidoId);
          return;
        }

        horarioInput.disabled = false;

        const esPrimerPartido = horarioInput.dataset.forceInicio === '1';
        if (esPrimerPartido) {
          horarioInput.value = horarioInput.dataset.inicioTorneo || '';
        }

        validarHorario(partidoId);
      });
    });

    document.querySelectorAll('input[id^="horario"]').forEach((element) => {
      element.addEventListener('change', (event) => {
        const partidoId = event.target.id.replace('horario', '');
        validarHorario(partidoId);
      });
    });
  </script>
{% endblock %}
