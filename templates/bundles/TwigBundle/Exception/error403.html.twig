{% extends 'base.html.twig' %}

{% block title %}No autorizado{% endblock %}

{% block body %}
<div class="row justify-content-center mt-4">
    <div class="col-md-8 col-lg-6">
        <div class="card border-warning shadow-sm">
            <div class="card-header bg-warning">No autorizado</div>
            <div class="card-body">
                <h5 class="card-title">Codigo 403</h5>
                <p class="card-text mb-3">No tienes permisos para acceder a este recurso.</p>
                <a href="javascript:history.back()" class="btn btn-outline-secondary">Volver</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
